    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "flag-icons": "^7.5.0",
    "lucide-react": "^0.468.0",
    "motion": "^12.42.2",
    "next": "15.1.11",
    "next-intl": "^4.13.1",
    "next-themes": "^0.4.6",
    "nuqs": "^2.2.3",
    "radix-ui": "^1.4.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
