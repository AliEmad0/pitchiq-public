    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.4",
    "csv-parse": "^6.2.1",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.1.6",
    "happy-dom": "^15.11.7",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "msw": "^2.14.6",
    "postcss": "^8.4.49",
    "prettier": "^3.8.3",
    "sharp": "0.33.5",
    "tailwindcss": "^4.0.0",
