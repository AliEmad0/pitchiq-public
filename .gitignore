.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
/.next/
/out/

# production builds
/build
/dist

# env files (secrets — NEVER commit)
.env
.env.*
!.env.example

