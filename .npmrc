# Skip pnpm's pre-script deps verification.
#
# pnpm 9+ runs a "are deps in sync with the lockfile" check before every
# `pnpm exec` / `pnpm run` invocation. When the project's node_modules
# was installed from one platform (WSL Linux) and a script runs from
# another (Windows git's sh.exe via the husky pre-commit hook), pnpm
# sees platform-specific subdeps and offers to purge + reinstall. That
# prompt needs a TTY; the hook runs without one, so the abort cascades
# into `[ERR_PNPM_ABORTED_REMOVE_MODULES_DIR_NO_TTY]` and the commit
# fails.
#
# `verify-deps-before-run=false` skips the verification entirely. CI
# already runs `pnpm install --frozen-lockfile` before any scripts, so
# the lockfile-vs-node_modules invariant is enforced where it matters.
verify-deps-before-run=false
