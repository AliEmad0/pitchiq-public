# ─── Vercel / runtime ──────────────────────────────────────────────────────
# REVALIDATE_SECRET protects the /api/admin/revalidate Route Handler that
# busts the Next.js fetch cache on demand. Generate with `openssl rand -hex 32`.
# Required on Vercel Production for the admin endpoint to work; without it,
# every request to /api/admin/revalidate returns 401 by design.
REVALIDATE_SECRET=generate_with_openssl_rand_hex_32

# ─── Sentry observability (added by TASK-005) ──────────────────────────────
# The DSN is browser-visible by design — that's how Sentry's Public Key model
# works; it's not a credential. Add NEXT_PUBLIC_ prefix so it reaches the
# client bundle. SENTRY_AUTH_TOKEN is for source-map uploads from CI/Vercel
# and MUST stay server-side only.
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
# SENTRY_AUTH_TOKEN=sntrys_*****  # set this in Vercel + GitHub Actions secrets

# ─── Site URL (added by TASK-109) ──────────────────────────────────────────
# Absolute origin used by `metadataBase` in `src/app/layout.tsx`. Drives
# OG/Twitter image URLs in social validators (LinkedIn, X/Twitter, Slack).
# Precedence: NEXT_PUBLIC_SITE_URL → https://${VERCEL_URL} → http://localhost:3000.
# Set this in Production env on Vercel once a stable canonical exists.
# NEXT_PUBLIC_SITE_URL=https://the-invincibles.vercel.app
